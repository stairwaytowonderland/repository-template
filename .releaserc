{
	"branches": [
		"main"
	],
	"tagFormat": "v${version}",
	"plugins": [
		"semantic-release-export-data",
		[
			"@semantic-release/changelog",
			{
				"changelogFile": "CHANGELOG.md"
			}
		],
		[
			"@semantic-release/commit-analyzer",
			{
				"preset": "conventionalcommits",
				"releaseRules": [
					{
						"type": "docs",
						"scope": "README",
						"release": "patch"
					},
					{
						"type": "chore",
						"release": false
					},
					{
						"type": "style",
						"release": false
					},
					{
						"scope": "no-release",
						"release": false
					}
				]
			}
		],
		[
			"@semantic-release/release-notes-generator",
			{
				"preset": "conventionalcommits",
				"presetConfig": {
					"types": [
						{
							"type": "feat",
							"section": "✨ Features"
						},
						{
							"type": "fix",
							"section": "🐛 Bug Fixes"
						},
						{
							"type": "perf",
							"section": "⚡ Performance"
						},
						{
							"type": "refactor",
							"section": "♻️ Refactoring"
						},
						{
							"type": "docs",
							"section": "📚 Documentation"
						},
						{
							"type": "build",
							"section": "🏗️ Build System"
						},
						{
							"type": "ci",
							"section": "🔄 CI/CD"
						},
						{
							"type": "test",
							"section": "🧪 Tests"
						},
						{
							"type": "chore",
							"section": "🔧 Chores"
						},
						{
							"type": "style",
							"section": "🎨 Styles"
						},
						{
							"type": "revert",
							"hidden": true
						}
					]
				}
			}
		],
		[
			"@semantic-release/npm",
			{
				"npmPublish": false
			}
		]
	]
}
